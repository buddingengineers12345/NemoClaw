{
  "mcpServers": {
    "agentmemory": {
      "env": {
        "AGENTMEMORY_TEAM_ID": "nemoclaw"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/engineer/.agentmemory/hooks/scoped-hook.sh session-start"
          }
        ],
        "description": "AgentMemory: register session and inject prior context"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/engineer/.agentmemory/hooks/scoped-hook.sh stop",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "AgentMemory: flush session observations on stop"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/engineer/.agentmemory/hooks/scoped-hook.sh pre-compact"
          }
        ],
        "description": "AgentMemory: preserve context before compaction"
      }
    ]
  }
}
